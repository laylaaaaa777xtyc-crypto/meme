{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "meme",
  "main": "_worker.ts",
  "compatibility_date": "2026-05-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    { "binding": "WISHES_KV", "id": "PLACEHOLDER_RUN_WRANGLER_KV_CREATE" }
  ]
}
